# ---- Supabase ----
# From your project's Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — NEVER expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# ---- Resend (transactional email) ----
RESEND_API_KEY=
EMAIL_FROM="SADEEM <hello@yourdomain.com>"
# Team mailbox that receives lead/booking/application notifications
TEAM_NOTIFY_TO=team@yourdomain.com

# ---- Google Calendar (Phase 5) ----
GOOGLE_SA_EMAIL=
# Paste the private_key from the service account JSON (multiline ok, keep the \n sequences)
GOOGLE_SA_PRIVATE_KEY=
GOOGLE_CALENDAR_ID=
GOOGLE_BOOKING_TIMEZONE=Asia/Riyadh

# ---- App ----
# Used for absolute URLs in emails (booking confirmations, magic links, etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
